---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Maria Isabel Begueri | Hospitality Professional">
  <!-- ═══════════════════════════════════════
      HERO SECTION
  ═══════════════════════════════════════ -->
  <section id="home" class="relative min-h-screen overflow-hidden">
    <!-- Parallax Background -->
    <div id="parallax-container" class="absolute inset-0">
      <div
        class="parallax-layer absolute inset-0"
        data-speed="0.1"
        style="background: linear-gradient(180deg, #FAE4D8 0%, #F8C8B0 30%, #E8A889 60%, #D4847A 100%);"
      >
      </div>

      <div
        class="parallax-layer absolute"
        data-speed="0.15"
        style="top:15%;left:50%;transform:translateX(-50%);"
      >
        <div
          class="w-32 h-32 md:w-48 md:h-48 rounded-full opacity-80"
          style="background:radial-gradient(circle,#FFF5E6,#FFD9B3);filter:blur(4px);"
        >
        </div>
      </div>

      <div
        class="parallax-layer absolute bottom-0 left-0 right-0 h-[60%]"
        data-speed="0.2"
      >
        <svg
          viewBox="0 0 1440 400"
          preserveAspectRatio="none"
          class="w-full h-full"
        >
          <path
            fill="#C9907A"
            d="M0,200 L100,180 L200,220 L350,150 L450,190 L550,130 L700,170 L850,110 L950,160 L1100,120 L1200,170 L1350,140 L1440,180 L1440,400 L0,400 Z"
          ></path>
        </svg>
      </div>

      <div
        class="parallax-layer absolute bottom-0 left-0 right-0 h-[50%]"
        data-speed="0.35"
      >
        <svg
          viewBox="0 0 1440 350"
          preserveAspectRatio="none"
          class="w-full h-full"
        >
          <path
            fill="#A66B5A"
            d="M0,250 L100,220 L180,240 L220,220 L280,240 L280,120 L320,120 L320,100 L380,100 L380,120 L420,120 L420,240 L500,220 L600,260 L650,240 L700,80 L720,80 L720,60 L760,60 L760,80 L780,80 L780,240 L850,220 L950,250 L1050,200 L1100,220 L1150,180 L1200,210 L1300,190 L1400,230 L1440,220 L1440,350 L0,350 Z"
          ></path>
          <rect
            fill="#FFE4C4"
            x="300"
            y="140"
            width="15"
            height="20"
            opacity="0.7"></rect>
          <rect
            fill="#FFE4C4"
            x="340"
            y="140"
            width="15"
            height="20"
            opacity="0.7"></rect>
          <rect
            fill="#FFE4C4"
            x="720"
            y="100"
            width="15"
            height="20"
            opacity="0.7"></rect>
          <rect
            fill="#FFE4C4"
            x="750"
            y="100"
            width="15"
            height="20"
            opacity="0.7"></rect>
        </svg>
      </div>

      <div
        class="parallax-layer absolute bottom-0 left-0 right-0 h-[30%]"
        data-speed="0.5"
      >
        <svg
          viewBox="0 0 1440 240"
          preserveAspectRatio="none"
          class="w-full h-full"
        >
          <path
            fill="#8B5A4A"
            d="M0,160 L200,120 L400,150 L700,100 L900,140 L1200,110 L1440,140 L1440,240 L0,240 Z"
          ></path>
        </svg>
      </div>

      <div
        class="parallax-layer absolute bottom-0 left-0 right-0 h-[20%]"
        data-speed="0.7"
      >
        <svg
          viewBox="0 0 1440 180"
          preserveAspectRatio="none"
          class="w-full h-full"
        >
          <path
            fill="#5C3D2E"
            d="M0,120 L300,90 L600,110 L900,80 L1200,100 L1440,90 L1440,180 L0,180 Z"
          ></path>
        </svg>
      </div>

      <div
        class="absolute bottom-0 left-0 right-0 h-40"
        style="background:linear-gradient(to top, #FDFBF7, transparent);"
      >
      </div>
    </div>

    <!-- Hero Content -->
    <div
      class="relative z-10 min-h-screen flex items-center justify-center px-6"
    >
      <div class="text-center max-w-3xl mx-auto" style="padding-top:5rem;">
        <p
          class="font-accent text-lg md:text-xl mb-4 opacity-0 hero-animate"
          style="animation-delay:0.2s;color:#7A4E38;text-shadow:0 1px 3px rgba(255,255,255,0.6);"
          data-en="Welcome to my world"
          data-sv="Välkommen till min värld"
        >
          Welcome to my world
        </p>

        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 opacity-0 hero-animate"
          style="animation-delay:0.4s;color:#2D2D2D;text-shadow:0 2px 12px rgba(255,255,255,0.5);"
        >
          <span class="lang-text" data-en="Hi, I'm" data-sv="Hej, jag är"
            >Hi, I'm</span
          >
          <span class="gradient-text block mt-1">Maria Isabel</span>
        </h1>

        <p
          class="text-lg md:text-2xl mb-10 opacity-0 hero-animate font-medium"
          style="animation-delay:0.6s;color:#3D3D3D;text-shadow:0 1px 6px rgba(255,255,255,0.5);"
        >
          <span
            class="lang-text"
            data-en="Creating warm welcomes & exceptional experiences"
            data-sv="Skapar varma välkomnanden & exceptionella upplevelser"
          >
            Creating warm welcomes &amp; exceptional experiences
          </span>
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 hero-animate"
          style="animation-delay:0.8s;"
        >
          <a
            href="#about"
            class="btn-primary lang-text"
            data-en="Discover My Story"
            data-sv="Upptäck Min Historia">Discover My Story</a
          >
          <a
            href="#contact"
            class="btn-secondary lang-text"
            data-en="Get In Touch"
            data-sv="Kontakta Mig">Get In Touch</a
          >
        </div>

        <!-- Scroll indicator -->
        <div
          class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-0 hero-animate"
          style="animation-delay:1.2s;"
        >
          <div
            class="w-6 h-10 border-2 border-white/60 rounded-full flex justify-center"
          >
            <div class="w-1 h-3 bg-white/60 rounded-full mt-2 animate-bounce">
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
      ABOUT SECTION
  ═══════════════════════════════════════ -->
  <section
    id="about"
    class="py-32 dark:bg-gray-900 transition-colors justify-center items-center flex min-h-screen m-4 p-4"
    style="background-color:var(--color-warm-white);"
  >
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal-section grid md:grid-cols-2 gap-16 items-center">
        <!-- Image column -->
        <div class="relative">
          <!-- Decorative blobs -->
          <div
            class="absolute -top-10 -left-10 w-40 h-40 rounded-full opacity-40 blur-3xl"
            style="background:var(--color-coral-light);"
          >
          </div>
          <div
            class="absolute -bottom-10 -right-10 w-48 h-48 rounded-full opacity-30 blur-3xl"
            style="background:var(--color-gold-light);"
          >
          </div>

          <!-- Photo -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl">
            <img
              src="https://ext.same-assets.com/94436006/1303403810.png"
              alt="Maria Isabel Begueri"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
            <div
              class="absolute inset-0"
              style="background:linear-gradient(to top, rgba(224,122,95,0.15), transparent);"
            >
            </div>
          </div>

          <!-- Floating card: Experience -->
          <div
            class="glass absolute right-2 md:-right-10 top-1/4 rounded-2xl p-4 shadow-xl animate-float flex flex-col items-center gap-1"
            style="animation-delay:0s;"
          >
            <p
              class="text-3xl font-bold items-center"
              style="color:var(--color-coral);"
            >
              15+
            </p>
            <p
              class="text-sm font-medium mt-0.5 lang-text px-2 text-center"
              style="color:var(--color-charcoal);"
              data-en="Years Experience"
              data-sv="Års Erfarenhet"
            >
              Years Experience
            </p>
          </div>

          <!-- Floating card: Languages -->
          <div
            class="glass absolute left-2 md:-left-10 bottom-1/4 rounded-2xl p-4 shadow-xl animate-float flex flex-col items-center gap-1"
            style="animation-delay:0.8s;"
          >
            <p class="text-3xl font-bold" style="color:var(--color-gold);">
              5+
            </p>
            <p
              class="text-sm font-medium mt-0.5 lang-text px-2 text-center"
              style="color:var(--color-charcoal);"
              data-en="Languages"
              data-sv="Språk"
            >
              Languages
            </p>
          </div>
        </div>

        <!-- Text column -->
        <div class="space-y-6 h-full flex flex-col justify-center gap-6">
          <p
            class="section-subtitle lang-text"
            data-en="Let me introduce myself"
            data-sv="Låt mig presentera mig"
          >
            Let me introduce myself
          </p>
          <h2
            class="section-title dark:text-white lang-text"
            data-en="More Than a Receptionist"
            data-sv="Mer Än En Receptionist"
          >
            More Than a Receptionist
          </h2>

          <div class="space-y-5 mt-6">
            <p
              class="text-base md:text-lg leading-relaxed dark:text-gray-300 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="I believe that every interaction is an opportunity to create a meaningful connection. With over 15 years in hospitality and customer service, I've learned that the key to excellence isn't just what you do — it's how you make people feel."
              data-sv="Jag tror att varje interaktion är en möjlighet att skapa en meningsfull koppling. Med över 15 års erfarenhet inom gästfrihet och kundservice har jag lärt mig att nyckeln till excellens inte bara är vad du gör — det är hur du får människor att känna sig."
            >
              I believe that every interaction is an opportunity to create a
              meaningful connection. With over 15 years in hospitality and
              customer service, I've learned that the key to excellence isn't
              just what you do — it's how you make people feel.
            </p>
            <p
              class="text-base md:text-lg leading-relaxed dark:text-gray-300 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="I'm a curious learner, a natural problem-solver, and someone who finds genuine joy in helping others. Whether it's welcoming guests to a hotel, managing car rental reservations, or supporting a team, I bring warmth, efficiency, and a smile to everything I do."
              data-sv="Jag är en nyfiken lärare, en naturlig problemlösare och någon som finner äkta glädje i att hjälpa andra. Oavsett om det handlar om att välkomna gäster till ett hotell, hantera biluthyrningsreservationer eller stödja ett team, går jag in med värme, effektivitet och ett leende i allt jag gör."
            >
              I'm a curious learner, a natural problem-solver, and someone who
              finds genuine joy in helping others.
            </p>
          </div>

          <!-- Values grid -->
          <div class="grid grid-cols-2 gap-6 mt-8">
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                style="background:var(--color-coral-light);"
              >
                <svg
                  class="w-5 h-5"
                  style="color:var(--color-coral-dark);"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                  ></path>
                </svg>
              </div>
              <span
                class="font-semibold text-sm dark:text-gray-200 lang-text"
                style="color:var(--color-charcoal);"
                data-en="Empathetic"
                data-sv="Empatisk">Empathetic</span
              >
            </div>

            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                style="background:var(--color-gold-light);"
              >
                <svg
                  class="w-5 h-5"
                  style="color:var(--color-terracotta);"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <span
                class="font-semibold text-sm dark:text-gray-200 lang-text"
                style="color:var(--color-charcoal);"
                data-en="Proactive"
                data-sv="Proaktiv">Proactive</span
              >
            </div>

            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                style="background:rgba(139,157,131,0.2);"
              >
                <svg
                  class="w-5 h-5"
                  style="color:var(--color-sage);"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                  ></path>
                </svg>
              </div>
              <span
                class="font-semibold text-sm dark:text-gray-200 lang-text"
                style="color:var(--color-charcoal);"
                data-en="Team Player"
                data-sv="Lagspelåre">Team Player</span
              >
            </div>

            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                style="background:var(--color-rose-light);"
              >
                <svg
                  class="w-5 h-5"
                  style="color:var(--color-terracotta);"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <span
                class="font-semibold text-sm dark:text-gray-200 lang-text"
                style="color:var(--color-charcoal);"
                data-en="Detail-Oriented"
                data-sv="Detaljorienterad">Detail-Oriented</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
      JOURNEY / TIMELINE SECTION
  ═══════════════════════════════════════ -->
  <section
    id="journey"
    class="py-32 dark:from-gray-800 dark:to-gray-900 transition-colors flex justify-center items-center m-4 p-4 min-h-screen"
    style="background:linear-gradient(to bottom, var(--color-cream), var(--color-warm-white));"
  >
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 reveal-section">
        <p
          class="section-subtitle lang-text"
          data-en="My Professional Path"
          data-sv="Min Professionella Väg"
        >
          My Professional Path
        </p>
        <h2
          class="section-title dark:text-white lang-text"
          data-en="A Journey of Growth"
          data-sv="En Resa Av Tillväxt"
        >
          A Journey of Growth
        </h2>
      </div>

      <div class="relative stagger-cards mt-6">
        <!-- Vertical line (desktop) -->
        <div
          class="absolute left-1/2 top-0 bottom-0 w-0.5 -translate-x-1/2 hidden md:block"
          style="background:linear-gradient(to bottom, var(--color-coral), var(--color-gold), var(--color-sage));"
        >
        </div>

        <div class="space-y-12">
          <!-- SIXT — left -->
          <div
            class="stagger-item relative flex flex-col md:flex-row items-start md:items-center gap-6"
          >
            <div class="w-full md:w-1/2 md:pr-12 md:text-right">
              <div class="card p-6">
                <span
                  class="badge mb-3"
                  style="background:var(--color-coral-light);color:var(--color-coral-dark);"
                  >2020 – Present</span
                >
                <h3
                  class="text-xl font-bold mb-1 dark:text-white lang-text"
                  style="color:var(--color-charcoal);"
                  data-en="Rental Agent"
                  data-sv="Uthyrningsagent"
                >
                  Rental Agent
                </h3>
                <p
                  class="font-semibold text-sm mb-2"
                  style="color:var(--color-coral);"
                >
                  SIXT Rent A Car
                </p>
                <p
                  class="text-sm leading-relaxed dark:text-gray-300 lang-text"
                  style="color:var(--color-charcoal-light);"
                  data-en="Managing reservations, customer service, fleet administration, and sales in a fast-paced environment."
                  data-sv="Hanterar reservationer, kundservice, flottadministration och försäljning i en snabb miljö."
                >
                  Managing reservations, customer service, fleet administration,
                  and sales in a fast-paced environment.
                </p>
              </div>
            </div>
            <!-- Dot -->
            <div class="timeline-dot" style="background:var(--color-coral);">
            </div>
            <div class="hidden md:block md:w-1/2"></div>
          </div>

          <!-- Europcar — right -->
          <div
            class="stagger-item relative flex flex-col md:flex-row items-start md:items-center gap-6"
          >
            <div class="hidden md:block md:w-1/2"></div>
            <div class="timeline-dot" style="background:var(--color-gold);">
            </div>
            <div class="w-full md:w-1/2 md:pl-12">
              <div class="card p-6">
                <span
                  class="badge mb-3"
                  style="background:var(--color-gold-light);color:var(--color-terracotta);"
                  >2015 – 2020</span
                >
                <h3
                  class="text-xl font-bold mb-1 dark:text-white lang-text"
                  style="color:var(--color-charcoal);"
                  data-en="Branch Manager"
                  data-sv="Filialchef"
                >
                  Branch Manager
                </h3>
                <p
                  class="font-semibold text-sm mb-2"
                  style="color:var(--color-coral);"
                >
                  Europcar
                </p>
                <p
                  class="text-sm leading-relaxed dark:text-gray-300 lang-text"
                  style="color:var(--color-charcoal-light);"
                  data-en="Led a team, managed operations, and achieved consistent customer satisfaction scores above 95%."
                  data-sv="Ledde ett team, hanterade verksamheten och uppnådde konstant kundnöjdhet över 95%."
                >
                  Led a team, managed operations, and achieved consistent
                  customer satisfaction scores above 95%.
                </p>
              </div>
            </div>
          </div>

          <!-- Quironsalud — left -->
          <div
            class="stagger-item relative flex flex-col md:flex-row items-start md:items-center gap-6"
          >
            <div class="w-full md:w-1/2 md:pr-12 md:text-right">
              <div class="card p-6">
                <span class="badge mb-3 bg-fuchsia-200 text-terracotta">
                  2012 – 2015</span
                >
                <h3
                  class="text-xl
                  font-bold
                  mb-1
                  lang-text
                  text-charcoal"
                  data-en="Administrative Receptionist"
                  data-sv="Administrativ Receptionist"
                >
                  Administrative Receptionist
                </h3>
                <p
                  class="font-semibold text-sm mb-2"
                  style="color:var(--color-coral);"
                >
                  Quironsalud
                </p>
                <p
                  class="text-sm leading-relaxed dark:text-gray-300 lang-text"
                  style="color:var(--color-charcoal-light);"
                  data-en="Managed patient reception, appointment scheduling, and administrative support in healthcare setting."
                  data-sv="Hanterade patientmottagning, tidsbokning och administrativt stöd i vårdmiljö."
                >
                  Managed patient reception, appointment scheduling, and
                  administrative support in healthcare setting.
                </p>
              </div>
            </div>
            <div class="timeline-dot bg-fuchsia-200"></div>
            <div class="hidden md:block md:w-1/2"></div>
          </div>

          <!-- Air Europa — right -->
          <div
            class="stagger-item relative flex flex-col md:flex-row items-start md:items-center gap-6"
          >
            <div class="hidden md:block md:w-1/2"></div>
            <div class="timeline-dot" style="background:var(--color-rose);">
            </div>
            <div class="w-full md:w-1/2 md:pl-12">
              <div class="card p-6">
                <span
                  class="badge mb-3"
                  style="background:var(--color-rose-light);color:var(--color-terracotta);"
                  >2008 – 2012</span
                >
                <h3
                  class="text-xl font-bold mb-1 dark:text-white lang-text"
                  style="color:var(--color-charcoal);"
                  data-en="Customer Service Agent"
                  data-sv="Kundserviceagent"
                >
                  Customer Service Agent
                </h3>
                <p
                  class="font-semibold text-sm mb-2"
                  style="color:var(--color-coral);"
                >
                  Air Europa
                </p>
                <p
                  class="text-sm leading-relaxed dark:text-gray-300 lang-text"
                  style="color:var(--color-charcoal-light);"
                  data-en="Provided multilingual customer support, handled reservations, and resolved travel-related inquiries."
                  data-sv="Gav flerspråkig kundsupport, hanterade reservationer och löste reserelaterade frågor."
                >
                  Provided multilingual customer support, handled reservations,
                  and resolved travel-related inquiries.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
      SKILLS SECTION
  ═══════════════════════════════════════ -->
  <section
    id="skills"
    class="dark:bg-gray-900 transition-colors flex justify-center items-center min-h-screen m-4 p-4 bg-warm-white"
    style="background-color:var(--color-warm-white);"
  >
    <div class="max-w-5xl mx-auto px-6 flex flex-col gap-6">
      <div class="text-center mb-16 reveal-section">
        <p
          class="section-subtitle lang-text"
          data-en="What I Bring"
          data-sv="Vad Jag Bidrar Med"
        >
          What I Bring
        </p>
        <h2
          class="section-title dark:text-white lang-text"
          data-en="Skills & Expertise"
          data-sv="Kompetens & Expertis"
        >
          Skills &amp; Expertise
        </h2>
      </div>

      <div class="space-y-12 flex flex-col gap-12 mb-6">
        <div class="grid md:grid-cols-2 gap-14 reveal-section">
          <!-- Languages -->
          <div class="reveal-section flex flex-col gap-6 mb-6">
            <div class="flex items-center gap-6 mb-8">
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
                style="background:var(--color-coral);"
              >
                <svg
                  class="w-5 h-5 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
