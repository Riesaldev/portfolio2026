---
import Layout from "@/layouts/Layout.astro";
import HeroParallax from "@/hero/HeroParallax.astro";
import HeroContent from "@/hero/HeroContent.astro";
import HeroNightStyles from "@/hero/HeroNightStyles.astro";
import About from "@/sections/About.astro";
import Journey from "@/sections/Journey.astro";
import Skills from "@/sections/Skills.astro";
import Contact from "@/sections/Contact.astro";
import NoiseTexture from "@/ui/NoiseTexture.astro";
---

<Layout title="Maria Isabel Begueri | Hospitality Professional">
  <!-- Hero (Paso H: noise layer) -->
  <section id="home" class="relative min-h-screen overflow-hidden">
    <HeroParallax />
    <HeroContent />
    <HeroNightStyles />
    <NoiseTexture opacity={0.055} blendMode="overlay" />
  </section>

  <!-- Sections -->
  <About />
  <Journey />
  <Skills />
  <Contact />
</Layout>

<style is:global>
  /* Fallback in case JS is disabled or fails: */
  .no-js .reveal-section {
    opacity: 1 !important;
    transform: none !important;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ─────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────
  const ease = "power3.out";

  // Set GSAP as master of reveal-section initial states
  gsap.set(".reveal-section", { opacity: 0, y: 44, force3D: true });

  // ─────────────────────────────────────────
  // Hero entrance
  // ─────────────────────────────────────────
  (() => {
    const tl = gsap.timeline({
      defaults: { ease: "power4.out", force3D: true },
    });

    const taglineEl = document.querySelector<HTMLElement>("#hero-tagline");
    const h1El = document.querySelector<HTMLElement>("#hero-h1");
    const subtitleEl = document.querySelector<HTMLElement>("#hero-subtitle");
    const ctas = document.querySelector("#hero-ctas");
    const scroll = document.querySelector("#scroll-indicator");

    // Tagline — whole element slide-up with blur (safe for lang-text)
    if (taglineEl) {
      gsap.set(taglineEl, { opacity: 0, y: 24, filter: "blur(4px)" });
      tl.to(
        taglineEl,
        {
          opacity: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.7,
        },
        0.2,
      );
    }

    // H1 "Hi, I'm" span — fade up
    const hiSpan = h1El?.querySelector<HTMLElement>(".lang-text");
    if (hiSpan) {
      gsap.set(hiSpan, { opacity: 0, y: 28 });
      tl.to(hiSpan, { opacity: 1, y: 0, duration: 0.7, ease }, 0.5);
    }

    // H1 "Maria Isabel" — simple fade+rise (word-split breaks background-clip:text)
    const nameSpan = h1El?.querySelector<HTMLElement>(".gradient-text");
    if (nameSpan) {
      gsap.set(nameSpan, { opacity: 0, y: 30 });
      tl.to(
        nameSpan,
        { opacity: 1, y: 0, duration: 0.9, ease: "power4.out" },
        0.65,
      );
    }

    if (subtitleEl) {
      gsap.set(subtitleEl, { opacity: 0, y: 22 });
      tl.to(subtitleEl, { opacity: 1, y: 0, duration: 0.75, ease }, 1.05);
    }

    if (ctas) {
      const btns = ctas.querySelectorAll("a");
      gsap.set(btns, { opacity: 0, y: 18 });
      tl.to(
        btns,
        { opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease },
        1.25,
      );
    }

    if (scroll) {
      gsap.set(scroll, { opacity: 0 });
      tl.to(scroll, { opacity: 1, duration: 0.7 }, 1.55);
    }
  })();

  document
    .querySelectorAll<HTMLElement>(".section-title")
    .forEach((titleEl) => {
      if (titleEl.dataset.splitDone) return;
      titleEl.dataset.splitDone = "1";

      const inner = document.createElement("span");
      inner.style.cssText = "display:block;";
      inner.innerHTML = titleEl.innerHTML;
      titleEl.style.overflow = "hidden";
      titleEl.style.display = "block";
      titleEl.innerHTML = "";
      titleEl.appendChild(inner);

      gsap.set(inner, { y: "100%" });
      gsap.to(inner, {
        y: "0%",
        duration: 0.9,
        ease: "power3.out",
        scrollTrigger: {
          trigger: titleEl,
          start: "top 89%",
          toggleActions: "play none none none",
        },
      });
    });

  // ─────────────────────────────────────────
  // Parallax on scroll
  // ─────────────────────────────────────────
  const parallaxLayers = document.querySelectorAll<HTMLElement>("[data-speed]");
  window.addEventListener(
    "scroll",
    () => {
      const sy = window.scrollY;
      parallaxLayers.forEach((l) => {
        const speed = parseFloat(l.dataset.speed ?? "0");
        l.style.transform = `translateY(${sy * speed}px)`;
      });
    },
    { passive: true },
  );

  // ─────────────────────────────────────────
  // reveal-section — fade up
  // ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".reveal-section").forEach((el) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.85,
      ease,
      scrollTrigger: {
        trigger: el,
        start: "top 88%",
        toggleActions: "play none none none",
      },
    });
  });

  // ─────────────────────────────────────────
  // stagger-cards — cascading entrance
  // ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".stagger-cards").forEach((grid) => {
    const items = grid.querySelectorAll<HTMLElement>(".stagger-item");
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.65,
      stagger: 0.1,
      ease,
      scrollTrigger: {
        trigger: grid,
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });
  });

  // ─────────────────────────────────────────
  // Section headers — subtitle then title
  // ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".section-subtitle").forEach((sub) => {
    gsap.fromTo(
      sub,
      { opacity: 0, y: 16 },
      {
        opacity: 1,
        y: 0,
        duration: 0.55,
        ease,
        scrollTrigger: {
          trigger: sub,
          start: "top 87%",
          toggleActions: "play none none none",
        },
      },
    );
  });

  // ─────────────────────────────────────────
  // Timeline items — alternate left / right
  // ─────────────────────────────────────────
  document
    .querySelectorAll<HTMLElement>(".timeline-item-left")
    .forEach((el) => {
      gsap.fromTo(
        el,
        { opacity: 0, x: -48 },
        {
          opacity: 1,
          x: 0,
          duration: 0.75,
          ease,
          scrollTrigger: {
            trigger: el,
            start: "top 88%",
            toggleActions: "play none none none",
          },
        },
      );
    });
  document
    .querySelectorAll<HTMLElement>(".timeline-item-right")
    .forEach((el) => {
      gsap.fromTo(
        el,
        { opacity: 0, x: 48 },
        {
          opacity: 1,
          x: 0,
          duration: 0.75,
          ease,
          scrollTrigger: {
            trigger: el,
            start: "top 88%",
            toggleActions: "play none none none",
          },
        },
      );
    });

  // ─────────────────────────────────────────
  // Skill bars
  // ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".skill-progress").forEach((bar) => {
    const target = bar.dataset.width ?? "0%";
    gsap.fromTo(
      bar,
      { width: "0%" },
      {
        width: target,
        duration: 1.6,
        ease: "power3.out",
        scrollTrigger: {
          trigger: bar,
          start: "top 90%",
          toggleActions: "play none none reset",
        },
      },
    );
  });

  // ─────────────────────────────────────────
  // Floating cards — continuous bob
  // ─────────────────────────────────────────
  gsap.utils.toArray<HTMLElement>(".animate-float").forEach((el, i) => {
    gsap.to(el, {
      y: -14,
      duration: 2.4 + i * 0.3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: i * 0.65,
    });
  });

  // ─────────────────────────────────────────
  // Cards — subtle entrance on About section
  // ─────────────────────────────────────────
  document.querySelectorAll<HTMLElement>(".card").forEach((card, i) => {
    // skip stagger-item cards (handled by stagger-cards above)
    if (card.classList.contains("stagger-item")) return;
    gsap.from(card, {
      opacity: 0,
      y: 30,
      scale: 0.97,
      duration: 0.7,
      ease,
      delay: i * 0.05,
      scrollTrigger: {
        trigger: card,
        start: "top 90%",
        toggleActions: "play none none none",
      },
    });
  });

  // ─────────────────────────────────────────
  // Contact section — form fields cascade
  // ─────────────────────────────────────────
  const contactForm = document.getElementById("contact-form");
  if (contactForm) {
    const fields = contactForm.querySelectorAll<HTMLElement>(
      ".form-input, .btn-primary",
    );
    gsap.fromTo(
      fields,
      { opacity: 0, y: 20 },
      {
        opacity: 1,
        y: 0,
        duration: 0.55,
        stagger: 0.08,
        ease,
        scrollTrigger: {
          trigger: contactForm,
          start: "top 85%",
          toggleActions: "play none none none",
        },
      },
    );
  }

  // ─────────────────────────────────────────
  // Contact form submit handler
  // ─────────────────────────────────────────
  const form = document.getElementById(
    "contact-form",
  ) as HTMLFormElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!btn) return;
    const orig = btn.innerHTML;
    btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Sent!</span>`;
    btn.style.background = "var(--color-sage)";
    btn.disabled = true;
    gsap.from(btn, { scale: 0.92, duration: 0.3, ease: "back.out(2)" });
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.style.background = "";
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
</script>
