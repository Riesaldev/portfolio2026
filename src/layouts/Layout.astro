---
import Navigation from "../components/Navigation.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta
      name="description"
      content="Maria Isabel Begueri - Professional receptionist and hospitality expert with multilingual skills and years of experience in customer service."
    />
    <meta name="author" content="Maria Isabel Begueri" />
    <meta
      name="keywords"
      content="receptionist, hospitality, customer service, multilingual, sweden, professional"
    />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#E07A5F" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Professional receptionist portfolio - Experienced in customer service and administration"
    />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="Professional receptionist portfolio"
    />
    <meta name="twitter:image" content="/og-image.png" />

    <!-- Preconnect to external resources for better performance -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="antialiased">
    <!-- Navigation -->
    <Navigation />

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer
      class="py-12 dark:bg-gray-900 transition-colors"
      style="background-color:var(--color-cream);"
    >
      <div class="max-w-7xl mx-auto px-6">
        <div
          class="flex flex-col md:flex-row justify-between items-center gap-6"
        >
          <div class="text-center md:text-left">
            <p
              class="text-sm dark:text-gray-400"
              style="color:var(--color-charcoal-light);"
            >
              <span
                class="lang-text"
                data-en="© 2026 Maria Isabel Begueri. All rights reserved."
                data-sv="© 2026 Maria Isabel Begueri. Alla rättigheter förbehållna."
              >
                © 2026 Maria Isabel Begueri. All rights reserved.
              </span>
            </p>
          </div>
          <div class="flex gap-5">
            <a
              href="https://www.linkedin.com/in/maria-i-begueri/"
              target="_blank"
              rel="noopener noreferrer"
              class="dark:text-gray-400 transition-colors hover:opacity-70"
              style="color:var(--color-charcoal-light);"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
            <a
              href="mailto:maria.begueri@email.com"
              class="dark:text-gray-400 transition-colors hover:opacity-70"
              style="color:var(--color-charcoal-light);"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Scroll to top button -->
    <button
      id="scroll-to-top"
      class="fixed bottom-8 right-8 w-12 h-12 text-white rounded-full shadow-lg opacity-0 invisible transition-all duration-300 flex items-center justify-center z-40"
      style="background:var(--color-coral);"
      aria-label="Scroll to top"
    >
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>
  </body>
</html>

<script>
  // Scroll to top button
  const scrollBtn = document.getElementById("scroll-to-top");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 300) {
      scrollBtn?.classList.remove("opacity-0", "invisible");
      scrollBtn?.classList.add("opacity-100", "visible");
    } else {
      scrollBtn?.classList.add("opacity-0", "invisible");
      scrollBtn?.classList.remove("opacity-100", "visible");
    }
  });

  scrollBtn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // Intersection Observer for reveal animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: "0px 0px -100px 0px",
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("visible", "active");
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe all reveal sections and stagger cards
  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll(".reveal-section, .stagger-cards")
      .forEach((el) => {
        observer.observe(el);
      });
  });
</script>

<style is:global>
  @import "tailwindcss";
</style>
