---

---

<div
  id="tools-physics-wrap"
  style="position:relative;width:100%;flex:1;min-height:320px;border-radius:16px;overflow:hidden;background:rgba(0,0,0,0.025);border:1px solid rgba(0,0,0,0.06);"
  class="dark:bg-[rgba(255,255,255,0.04)] dark:border-[rgba(255,255,255,0.08)]"
>
  <canvas
    id="tools-canvas"
    style="display:block;width:100%;height:100%;cursor:grab;"></canvas>
  <p
    style="position:absolute;top:10px;font-size:0.65rem;opacity:0.35;pointer-events:none;"
  >
    drag to play
  </p>
</div>

<script>
  import Matter from "matter-js";

  (function initToolsPhysics() {
    function setup() {
      var wrap = document.getElementById("tools-physics-wrap");
      var canvas = document.getElementById(
        "tools-canvas",
      ) as HTMLCanvasElement | null;
      if (!wrap || !canvas) return;

      var W = wrap.offsetWidth;
      var H = wrap.offsetHeight || 480;
      canvas.width = W;
      canvas.height = H;
      var ctx = canvas.getContext("2d") as CanvasRenderingContext2D;
      var M = Matter;

      var engine = M.Engine.create({ gravity: { y: 0.5 } });
      var world = engine.world;

      var tools = [
        { label: "AHM", color: "#D4845A" },
        { label: "Amadeus", color: "#C9963A" },
        { label: "NewHotel", color: "#7A9D74" },
        { label: "Trello", color: "#4E8EC4" },
        { label: "MasterYield", color: "#C9963A" },
        { label: "Greenway", color: "#5C9E55" },
        { label: "Office 365", color: "#D05A3A" },
        { label: "Google WS", color: "#E08C3A" },
        { label: "Canva", color: "#C45A82" },
      ];

      var PW = 118,
        PH = 46,
        PR = 23;

      var pillBodies = tools.map(function (t, i) {
        var col = i % 3;
        var row = Math.floor(i / 3);
        var x = 70 + col * (W / 3) + (Math.random() - 0.5) * 30;
        var y = 50 + row * 90 + Math.random() * 20;
        var b = M.Bodies.rectangle(x, y, PW, PH, {
          chamfer: { radius: PR },
          restitution: 0.45,
          friction: 0.08,
          frictionAir: 0.012,
          label: t.label,
        });
        b._color = t.color;
        b._isBall = false;
        M.Body.setAngularVelocity(b, (Math.random() - 0.5) * 0.12);
        return b;
      });

      var balls = [
        { color: "#D4845A", r: 22 },
        { color: "#4E8EC4", r: 18 },
        { color: "#7A9D74", r: 24 },
        { color: "#C45A82", r: 16 },
        { color: "#C9963A", r: 20 },
        { color: "#8B6FB5", r: 15 },
      ].map(function (b, i) {
        var x = 40 + i * ((W - 80) / 5) + (Math.random() - 0.5) * 20;
        var y = 30 + Math.random() * 60;
        var body = M.Bodies.circle(x, y, b.r, {
          restitution: 0.62,
          friction: 0.04,
          frictionAir: 0.008,
          label: "",
        });
        body._color = b.color;
        body._r = b.r;
        body._isBall = true;
        M.Body.setAngularVelocity(body, (Math.random() - 0.5) * 0.2);
        return body;
      });

      var bodies = pillBodies.concat(balls);
      var thick = 60;
      var walls = [
        M.Bodies.rectangle(W / 2, H + thick / 2, W + thick * 2, thick, {
          isStatic: true,
          label: "wall",
        }),
        M.Bodies.rectangle(-thick / 2, H / 2, thick, H + thick * 2, {
          isStatic: true,
          label: "wall",
        }),
        M.Bodies.rectangle(W + thick / 2, H / 2, thick, H + thick * 2, {
          isStatic: true,
          label: "wall",
        }),
        M.Bodies.rectangle(W / 2, -thick / 2, W + thick * 2, thick, {
          isStatic: true,
          label: "wall",
        }),
      ];

      M.Composite.add(world, pillBodies.concat(balls).concat(walls));

      var mouse = M.Mouse.create(canvas);

      var mc = M.MouseConstraint.create(engine, {
        mouse: mouse,
        constraint: {
          stiffness: 0.18,
          angularStiffness: 0.02,
          render: { visible: false },
        },
      });
      M.Composite.add(world, mc);

      canvas.addEventListener("mousedown", function () {
        (canvas as HTMLCanvasElement).style.cursor = "grabbing";
      });
      canvas.addEventListener("mouseup", function () {
        (canvas as HTMLCanvasElement).style.cursor = "grab";
      });

      M.Runner.run(M.Runner.create(), engine);

      function rr(
        c: CanvasRenderingContext2D,
        x: number,
        y: number,
        w: number,
        h: number,
        r: number,
      ) {
        c.beginPath();
        c.moveTo(x + r, y);
        c.lineTo(x + w - r, y);
        c.arcTo(x + w, y, x + w, y + r, r);
        c.lineTo(x + w, y + h - r);
        c.arcTo(x + w, y + h, x + w - r, y + h, r);
        c.lineTo(x + r, y + h);
        c.arcTo(x, y + h, x, y + h - r, r);
        c.lineTo(x, y + r);
        c.arcTo(x, y, x + r, y, r);
        c.closePath();
      }

      function hex2rgb(hex: string, a: number): string {
        var r = parseInt(hex.slice(1, 3), 16);
        var g = parseInt(hex.slice(3, 5), 16);
        var b = parseInt(hex.slice(5, 7), 16);
        return "rgba(" + r + "," + g + "," + b + "," + a + ")";
      }
      function lighten(hex: string): string {
        var r = Math.min(255, parseInt(hex.slice(1, 3), 16) + 60);
        var g = Math.min(255, parseInt(hex.slice(3, 5), 16) + 60);
        var b = Math.min(255, parseInt(hex.slice(5, 7), 16) + 60);
        return "rgb(" + r + "," + g + "," + b + ")";
      }

      function draw() {
        requestAnimationFrame(draw);
        var dark = document.documentElement.classList.contains("dark");
        ctx.clearRect(0, 0, W, H);

        bodies.forEach(function (body) {
          var pos = body.position;
          var ang = body.angle;
          ctx.save();
          ctx.translate(pos.x, pos.y);
          ctx.rotate(ang);

          if (body._isBall) {
            var br = body._r;
            ctx.shadowColor = "rgba(0,0,0,0.28)";
            ctx.shadowBlur = 12;
            ctx.shadowOffsetY = 4;
            ctx.beginPath();
            ctx.arc(0, 0, br, 0, Math.PI * 2);
            var grd = ctx.createRadialGradient(
              -br * 0.28,
              -br * 0.28,
              br * 0.05,
              0,
              0,
              br,
            );
            grd.addColorStop(
              0,
              dark ? hex2rgb(body._color, 0.95) : lighten(body._color),
            );
            grd.addColorStop(1, dark ? hex2rgb(body._color, 0.4) : body._color);
            ctx.fillStyle = grd;
            ctx.fill();
            ctx.shadowBlur = 0;
            ctx.shadowOffsetY = 0;
            ctx.beginPath();
            ctx.arc(0, 0, br, 0, Math.PI * 2);
            ctx.strokeStyle = "rgba(255,255,255,0.35)";
            ctx.lineWidth = 1.5;
            ctx.stroke();
          } else {
            var hw = PW / 2,
              hh = PH / 2;
            ctx.shadowColor = "rgba(0,0,0,0.22)";
            ctx.shadowBlur = 14;
            ctx.shadowOffsetY = 5;
            rr(ctx, -hw, -hh, PW, PH, PR);
            ctx.fillStyle = dark ? hex2rgb(body._color, 0.22) : "#ffffff";
            ctx.fill();
            ctx.shadowBlur = 0;
            ctx.shadowOffsetY = 0;
            rr(ctx, -hw, -hh, PW, PH, PR);
            ctx.strokeStyle = body._color;
            ctx.lineWidth = 2.2;
            ctx.stroke();
            ctx.save();
            ctx.beginPath();
            ctx.rect(-hw, -hh + PR, 5, PH - PR * 2);
            ctx.fillStyle = body._color;
            ctx.fill();
            ctx.restore();
            ctx.fillStyle = dark ? "#f0f0f0" : "#2a2a2a";
            ctx.font = "bold 12.5px system-ui,sans-serif";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText(body.label, 3, 0);
          }
          ctx.restore();
        });
      }
      draw();
    }

    function run() {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () =>
          requestAnimationFrame(setup),
        );
      } else {
        requestAnimationFrame(setup);
      }
    }
    run();
  })();
</script>
