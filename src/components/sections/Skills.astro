---
import SectionHeader from "@/ui/SectionHeader.astro";
import SkillBar from "@/ui/SkillBar.astro";
import ToolsPhysics from "@/physics/ToolsPhysics.astro";
import { languages } from "@/data/languages.js";
---

<section
  id="skills"
  class="dark:bg-gray-900 transition-colors flex justify-center items-center min-h-screen m-4 p-4 bg-warm-white"
  style="background-color:var(--color-warm-white);"
>
  <div class="max-w-5xl mx-auto px-6 flex flex-col gap-6">
    <SectionHeader
      subtitleEn="What I Bring"
      subtitleSv="Vad Jag Bidrar Med"
      titleEn="Skills & Expertise"
      titleSv="Kompetens & Expertis"
    />

    <div class="space-y-12 flex flex-col gap-12 mb-6">
      <div class="grid md:grid-cols-2 gap-14 reveal-section">
        <!-- Languages column -->
        <div class="reveal-section flex flex-col gap-6 mb-6">
          <div class="flex items-center gap-6 mb-8">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
              style="background:var(--color-coral);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-bold dark:text-white lang-text mt-6w"
              style="color:var(--color-charcoal);"
              data-en="Languages"
              data-sv="Språk"
            >
              Languages
            </h3>
          </div>

          <div class="space-y-5 mt-6 flex flex-col gap-6">
            {
              languages.map((lang) => (
                <SkillBar
                  labelEn={lang.labelEn}
                  labelSv={lang.labelSv}
                  percent={lang.percent}
                  gradient={lang.gradient}
                />
              ))
            }
          </div>
        </div>

        <!-- Professional Tools column -->
        <div class="reveal-section flex flex-col gap-6 mb-6 h-full">
          <div class="flex items-center gap-3 mb-8">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center shrink-0"
              style="background:var(--color-gold);"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-xl font-bold dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en="Professional Tools"
              data-sv="Professionella Verktyg"
            >
              Professional Tools
            </h3>
          </div>

          <ToolsPhysics />
        </div>
      </div>

      <!-- Services grid -->
      <div class="reveal-section flex flex-col gap-6">
        <h3
          class="text-2xl font-bold text-center dark:text-white lang-text"
          style="color:var(--color-charcoal);"
          data-en="What I Can Do For You"
          data-sv="Vad Jag Kan Göra För Dig"
        >
          What I Can Do For You
        </h3>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-cards">
          <!-- Reception -->
          <div class="stagger-item card p-8 text-center group">
            <div
              class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-110"
              style="background:linear-gradient(135deg,var(--color-coral),var(--color-terracotta));"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                ></path>
              </svg>
            </div>
            <h4
              class="text-base font-bold mb-2 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en="Reception"
              data-sv="Reception"
            >
              Reception
            </h4>
            <p
              class="text-sm leading-relaxed dark:text-gray-400 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="Front desk management, guest services, check-in/out"
              data-sv="Receptionstjänster, gästtjänster, in-/utcheckning"
            >
              Front desk management, guest services, check-in/out
            </p>
          </div>

          <!-- Administrative -->
          <div class="stagger-item card p-8 text-center group">
            <div
              class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-110"
              style="background:linear-gradient(135deg,var(--color-gold),var(--color-terracotta));"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
            </div>
            <h4
              class="text-base font-bold mb-2 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en="Administrative"
              data-sv="Administrativ"
            >
              Administrative
            </h4>
            <p
              class="text-sm leading-relaxed dark:text-gray-400 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="Documentation, scheduling, correspondence"
              data-sv="Dokumentation, schemaläggning, korrespondens"
            >
              Documentation, scheduling, correspondence
            </p>
          </div>

          <!-- Personal Assistant -->
          <div class="stagger-item card p-8 text-center group">
            <div
              class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-110"
              style="background:linear-gradient(135deg,var(--color-sage),var(--color-gold));"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
            </div>
            <h4
              class="text-base font-bold mb-2 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en="Personal Assistant"
              data-sv="Personlig Assistent"
            >
              Personal Assistant
            </h4>
            <p
              class="text-sm leading-relaxed dark:text-gray-400 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="Calendar management, travel arrangements, support"
              data-sv="Kalenderhantering, resebokningar, stöd"
            >
              Calendar management, travel arrangements, support
            </p>
          </div>

          <!-- Translation -->
          <div class="stagger-item card p-8 text-center group">
            <div
              class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-110"
              style="background:linear-gradient(135deg,var(--color-rose),var(--color-coral));"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                ></path>
              </svg>
            </div>
            <h4
              class="text-base font-bold mb-2 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en="Translation"
              data-sv="Översättning"
            >
              Translation
            </h4>
            <p
              class="text-sm leading-relaxed dark:text-gray-400 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en="Multilingual communication support"
              data-sv="Flerspråkigt kommunikationsstöd"
            >
              Multilingual communication support
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
