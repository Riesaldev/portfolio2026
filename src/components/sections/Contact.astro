---

---

<section
  id="contact"
  class="dark:from-gray-800 dark:to-gray-900 transition-colors flex justify-center items-center m-4 p-4 min-h-screen"
  style="background:linear-gradient(to bottom, var(--color-cream), var(--color-blush));"
>
  <div class="max-w-5xl mx-auto flex flex-col gap-6 px-6">
    <div class="text-center reveal-section flex flex-col gap-4">
      <p
        class="section-subtitle lang-text flex justify-center"
        data-en="Let's Connect"
        data-sv="Låt Oss Connecta"
      >
        Let's Connect
      </p>
      <h2
        class="section-title dark:text-white lang-text"
        data-en="Get In Touch"
        data-sv="Kontakta Mig"
      >
        Get In Touch
      </h2>
      <p
        class="mt-4 text-base leading-relaxed dark:text-gray-400 lang-text"
        style="color:var(--color-charcoal-light);"
        data-en="Whether you're looking for a dedicated professional or want to discuss how I can contribute to your organization, I'd love to hear from you."
        data-sv="Oavsett om du letar efter en engagerad professionell eller vill diskutera hur jag kan bidra till din organisation, skulle jag gärna höra från dig."
      >
        Whether you're looking for a dedicated professional or want to discuss
        how I can contribute to your organization, I'd love to hear from you.
      </p>
    </div>

    <div class="reveal-section flex flex-col gap-10">
      <form id="contact-form" class="flex flex-col gap-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label
              class="form-label lang-text flex items-center justify-center gap-1"
              data-en="Your Name"
              data-sv="Ditt Namn">Your Name</label
            >
            <input
              type="text"
              name="name"
              required
              class="form-input"
              placeholder="Anna Svensson"
            />
          </div>
          <div>
            <label
              class="form-label lang-text flex items-center justify-center gap-1"
              data-en="Email Address"
              data-sv="E-postadress">Email Address</label
            >
            <input
              type="email"
              name="email"
              required
              class="form-input"
              placeholder="anna@foretag.se"
            />
          </div>
        </div>

        <div>
          <label
            class="form-label lang-text flex items-center justify-center gap-1"
            data-en="Company (optional)"
            data-sv="Företag (valfritt)">Company (optional)</label
          >
          <input
            type="text"
            name="company"
            class="form-input"
            placeholder="Företag AB"
          />
        </div>

        <div>
          <label
            class="form-label lang-text flex items-center justify-center gap-1"
            data-en="Subject"
            data-sv="Ämne">Subject</label
          >
          <input
            type="text"
            name="subject"
            required
            class="form-input"
            placeholder="Job opportunity / Collaboration..."
          />
        </div>

        <div>
          <label
            class="form-label lang-text flex items-center justify-center gap-1"
            data-en="Your Message"
            data-sv="Ditt Meddelande">Your Message</label
          >
          <textarea
            name="message"
            rows="2"
            required
            class="form-input"
            placeholder="Tell me about the opportunity..."></textarea>
        </div>

        <div class="pt-2 text-center">
          <button type="submit" class="btn-primary" id="submit-btn">
            <span
              class="lang-text"
              data-en="Send Message"
              data-sv="Skicka Meddelande">Send Message</span
            >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </button>
        </div>
      </form>

      <!-- Alternative contact methods -->
      <div
        class="mt-10 pt-8 flex flex-col gap-6 items-center justify-center"
        style="border-top:1px solid var(--color-cream-dark);"
      >
        <p
          class="text-center text-sm dark:text-gray-400 mb-6 lang-text"
          style="color:var(--color-charcoal-light);"
          data-en="Or reach me directly"
          data-sv="Eller nå mig direkt"
        >
          Or reach me directly
        </p>

        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="https://www.linkedin.com/in/maria-i-begueri/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-5 py-3 rounded-full transition-all hover:-translate-y-0.5"
            style="background:var(--color-cream);color:var(--color-charcoal);"
            onmouseover="this.style.background='var(--color-coral)';this.style.color='white';"
            onmouseout="this.style.background='var(--color-cream)';this.style.color='var(--color-charcoal)';"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>

          <a
            href="mailto:maria.begueri@email.com"
            class="flex items-center gap-3 px-5 py-3 rounded-full transition-all hover:-translate-y-0.5"
            style="background:var(--color-cream);color:var(--color-charcoal);"
            onmouseover="this.style.background='var(--color-gold)';this.style.color='white';"
            onmouseout="this.style.background='var(--color-cream)';this.style.color='var(--color-charcoal)';"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
