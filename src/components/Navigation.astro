---
// Navigation component with smooth scroll and active states
import DarkModeToggle from "./DarkModeToggle";
import LanguageSwitcher from "./LanguageSwitcher";
---

<nav id="navbar" class="sticky top-0 w-full z-40 transition-all duration-300">
  <div class="w-full px-6 md:px-12 py-4 flex items-center">
    <!-- Logo -->
    <div class="flex-1 flex items-center">
      <a
        href="#home"
        class="text-4xl font-display font-extrabold text-[var(--color-charcoal)] dark:text-white transition-colors"
      >
        <span class="gradient-text">Maria Isabel</span>
      </a>
    </div>

    <!-- Desktop Menu -->
    <ul class="hidden md:flex flex-1 justify-center items-center gap-8">
      <li>
        <a
          href="#home"
          class="nav-link text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Home"
          data-sv="Hem">Home</a
        >
      </li>
      <li>
        <a
          href="#about"
          class="nav-link text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="About"
          data-sv="Om Mig">About</a
        >
      </li>
      <li>
        <a
          href="#journey"
          class="nav-link text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Journey"
          data-sv="Resa">Journey</a
        >
      </li>
      <li>
        <a
          href="#skills"
          class="nav-link text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Skills"
          data-sv="Kompetens">Skills</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="btn-primary lang-text"
          data-en="Contact"
          data-sv="Kontakt">Contact</a
        >
      </li>
    </ul>

    <!-- Toggles + Mobile Button -->
    <div class="flex-1 flex justify-end items-center gap-4">
      <div class="Toggles hidden md:flex items-center gap-4">
        <LanguageSwitcher client:load />
        <DarkModeToggle client:load />
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 group"
        aria-label="Toggle menu"
      >
        <span
          class="w-6 h-0.5 bg-[var(--color-charcoal)] dark:bg-white transition-all duration-300 group-[.active]:rotate-45 group-[.active]:translate-y-2"
        ></span>
        <span
          class="w-6 h-0.5 bg-[var(--color-charcoal)] dark:bg-white transition-all duration-300 group-[.active]:opacity-0"
        ></span>
        <span
          class="w-6 h-0.5 bg-[var(--color-charcoal)] dark:bg-white transition-all duration-300 group-[.active]:-rotate-45 group-[.active]:-translate-y-2"
        ></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden max-h-0 overflow-hidden transition-all duration-300 bg-white dark:bg-gray-900 shadow-lg"
  >
    <ul class="flex flex-col items-center gap-6 py-8">
      <li>
        <a
          href="#home"
          class="nav-link mobile-nav-link text-2xl text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Home"
          data-sv="Hem">Home</a
        >
      </li>
      <li>
        <a
          href="#about"
          class="nav-link mobile-nav-link text-2xl text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="About"
          data-sv="Om Mig">About</a
        >
      </li>
      <li>
        <a
          href="#journey"
          class="nav-link mobile-nav-link text-2xl text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Journey"
          data-sv="Resa">Journey</a
        >
      </li>
      <li>
        <a
          href="#skills"
          class="nav-link mobile-nav-link text-2xl text-[var(--color-charcoal-light)] dark:text-gray-300 font-medium transition-all duration-300 hover:text-[var(--color-coral)] dark:hover:text-[var(--color-coral-light)] relative lang-text"
          data-en="Skills"
          data-sv="Kompetens">Skills</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="btn-primary lang-text"
          data-en="Contact"
          data-sv="Kontakt">Contact</a
        >
      </li>
      <li class="flex items-center gap-3 pt-2">
        <LanguageSwitcher client:load />
        <DarkModeToggle client:load />
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-coral);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  #navbar.scrolled {
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  :global(.dark) #navbar.scrolled {
    background-color: rgba(17, 24, 39, 0.8);
  }
</style>

<script>
  // Smooth scroll
  document
    .querySelectorAll<HTMLAnchorElement>('a[href^="#"]')
    .forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.preventDefault();
        const href = anchor.getAttribute("href");
        const target = href ? document.querySelector(href) : null;
        if (target) {
          target.scrollIntoView({ behavior: "smooth" });
          // Close mobile menu if open
          const mobileMenu = document.getElementById("mobile-menu");
          const mobileMenuBtn = document.getElementById("mobile-menu-btn");
          if (mobileMenu && mobileMenuBtn) {
            mobileMenu.style.maxHeight = "0";
            mobileMenuBtn.classList.remove("active");
          }
        }
      });
    });

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenuBtn.classList.toggle("active");
    if (mobileMenu) {
      if (mobileMenu.style.maxHeight === "0px" || !mobileMenu.style.maxHeight) {
        mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
      } else {
        mobileMenu.style.maxHeight = "0";
      }
    }
  });

  // Navbar scroll effect
  const navbar = document.getElementById("navbar");
  let lastScroll = 0;

  window.addEventListener("scroll", () => {
    const currentScroll = window.pageYOffset;

    if (currentScroll > 50) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }

    // Active section highlighting
    const sections = document.querySelectorAll("section[id]");
    sections.forEach((section) => {
      const sectionTop = (section as HTMLElement).offsetTop - 100;
      const sectionHeight = (section as HTMLElement).offsetHeight;
      const sectionId = section.getAttribute("id");

      if (
        currentScroll >= sectionTop &&
        currentScroll < sectionTop + sectionHeight
      ) {
        document.querySelectorAll(".nav-link").forEach((link) => {
          link.classList.remove("active");
          if (link.getAttribute("href") === `#${sectionId}`) {
            link.classList.add("active");
          }
        });
      }
    });

    lastScroll = currentScroll;
  });
</script>
