---
import type { TimelineEntry } from "../../data/timeline";

interface Props {
  entry: TimelineEntry;
}
const { entry } = Astro.props;
const isLeft = entry.side === "left";
---

<div
  class={`stagger-item relative flex flex-col md:flex-row items-start md:items-center gap-6 ${isLeft ? "timeline-item-left" : "timeline-item-right"}`}
>
  {
    isLeft ? (
      <>
        <div class="w-full md:w-1/2 md:pr-12 md:text-right">
          <div class="card p-6">
            <span class="badge mb-3" style={entry.badgeStyle}>
              {entry.period}
            </span>
            <h3
              class="text-xl font-bold mb-1 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en={entry.roleEn}
              data-sv={entry.roleSv}
            >
              {entry.roleEn}
            </h3>
            <p
              class="font-semibold text-sm mb-2"
              style="color:var(--color-coral);"
            >
              {entry.company}
            </p>
            <p
              class="text-sm leading-relaxed dark:text-gray-300 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en={entry.descEn}
              data-sv={entry.descSv}
            >
              {entry.descEn}
            </p>
          </div>
        </div>
        <div class="timeline-dot" style={`background:${entry.dotColor};`} />
        <div class="hidden md:block md:w-1/2" />
      </>
    ) : (
      <>
        <div class="hidden md:block md:w-1/2" />
        <div class="timeline-dot" style={`background:${entry.dotColor};`} />
        <div class="w-full md:w-1/2 md:pl-12">
          <div class="card p-6">
            <span class="badge mb-3" style={entry.badgeStyle}>
              {entry.period}
            </span>
            <h3
              class="text-xl font-bold mb-1 dark:text-white lang-text"
              style="color:var(--color-charcoal);"
              data-en={entry.roleEn}
              data-sv={entry.roleSv}
            >
              {entry.roleEn}
            </h3>
            <p
              class="font-semibold text-sm mb-2"
              style="color:var(--color-coral);"
            >
              {entry.company}
            </p>
            <p
              class="text-sm leading-relaxed dark:text-gray-300 lang-text"
              style="color:var(--color-charcoal-light);"
              data-en={entry.descEn}
              data-sv={entry.descSv}
            >
              {entry.descEn}
            </p>
          </div>
        </div>
      </>
    )
  }
</div>
