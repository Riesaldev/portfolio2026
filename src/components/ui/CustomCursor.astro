---

<div id="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" aria-hidden="true"></div>

<style is:global>
  @media (pointer: fine) {
    *,
    *::before,
    *::after {
      cursor: none !important;
    }
  }

  #cursor-dot,
  #cursor-ring {
    pointer-events: none;
    position: fixed;
    top: 0;
    left: 0;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 9999;
    transition: opacity 0.3s;
  }

  #cursor-dot {
    width: 8px;
    height: 8px;
    background: var(--color-coral, #c0624a);
    mix-blend-mode: normal;
    will-change: transform;
  }

  #cursor-ring {
    width: 36px;
    height: 36px;
    border: 2px solid var(--color-coral, #c0624a);
    opacity: 0.55;
    will-change: transform;
    transition:
      width 0.22s ease,
      height 0.22s ease,
      opacity 0.22s ease,
      background 0.22s ease,
      border-color 0.22s ease;
  }

  .cursor-hover #cursor-ring {
    width: 54px;
    height: 54px;
    opacity: 0.85;
    background: rgba(192, 98, 74, 0.1);
  }

  .cursor-text #cursor-ring {
    width: 4px;
    height: 40px;
    border-radius: 2px;
    opacity: 0.7;
  }

  .cursor-hidden #cursor-dot,
  .cursor-hidden #cursor-ring {
    opacity: 0;
  }
</style>

<script>
  (function () {
    if (!window.matchMedia("(pointer: fine)").matches) return;

    const dot = document.getElementById("cursor-dot")!;
    const ring = document.getElementById("cursor-ring")!;
    const html = document.documentElement;

    let mx = -200,
      my = -200;
    let rx = -200,
      ry = -200;

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
      dot.style.transform = `translate(${mx - 4}px, ${my - 4}px)`;
      html.classList.remove("cursor-hidden");
    });

    document.addEventListener("mouseleave", () =>
      html.classList.add("cursor-hidden"),
    );
    document.addEventListener("mouseenter", () =>
      html.classList.remove("cursor-hidden"),
    );

    function animateRing() {
      rx += (mx - rx) * 0.14;
      ry += (my - ry) * 0.14;
      ring.style.transform = `translate(${rx - 18}px, ${ry - 18}px)`;
      requestAnimationFrame(animateRing);
    }
    animateRing();

    const interactive =
      "a, button, [role='button'], input, textarea, select, label, .btn-primary, .card, [data-cursor='hover']";
    const textInputs = "input[type='text'], input[type='email'], textarea";

    document.addEventListener("mouseover", (e) => {
      const el = (e.target as Element).closest(interactive);
      const isText = (e.target as Element).closest(textInputs);
      html.classList.toggle("cursor-hover", !!el && !isText);
      html.classList.toggle("cursor-text", !!isText);
    });

    document.addEventListener("mouseout", () => {
      html.classList.remove("cursor-hover", "cursor-text");
    });

    document.addEventListener("mousedown", () => {
      dot.style.transform = `translate(${mx - 3}px, ${my - 3}px) scale(0.75)`;
    });
    document.addEventListener("mouseup", () => {
      dot.style.transform = `translate(${mx - 4}px, ${my - 4}px) scale(1)`;
    });
  })();
</script>
