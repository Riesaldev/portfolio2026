---

---

<div class="relative z-10 min-h-screen flex items-start justify-center px-6">
  <div class="text-center max-w-3xl mx-auto" style="padding-top:5rem;">
    <p
      class="font-accent text-xl md:text-2xl mb-4 lang-text"
      id="hero-tagline"
      style="color:#3A1808;text-shadow:0 1px 6px rgba(255,255,255,0.7);font-style:italic;letter-spacing:0.02em;"
      data-en="Welcome to my world"
      data-sv="Välkommen till min värld"
    >
      Welcome to my world
    </p>

    <h1 class="display-text font-bold mb-6" id="hero-h1" style="color:#1A0C04;">
      <span class="lang-text" data-en="Hi, I'm" data-sv="Hej, jag är"
        >Hi, I'm</span
      >
      <span
        class="gradient-text block mt-1"
        style="text-shadow:none;filter:none;">Maria Isabel</span
      >
    </h1>

    <p
      class="lead mb-10"
      id="hero-subtitle"
      style="color:#2D1005;text-shadow:0 1px 8px rgba(255,255,255,0.6);"
    >
      <span
        class="lang-text"
        data-en="Creating warm welcomes & exceptional experiences"
        data-sv="Skapar varma välkomnanden & exceptionella upplevelser"
      >
        Creating warm welcomes &amp; exceptional experiences
      </span>
    </p>

    <div
      id="hero-ctas"
      class="flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <a
        href="#about"
        class="btn-primary lang-text"
        data-en="Discover My Story"
        data-sv="Upptäck Min Historia">Discover My Story</a
      >
      <a
        href="#contact"
        class="btn-secondary lang-text"
        data-en="Get In Touch"
        data-sv="Kontakta Mig">Get In Touch</a
      >
    </div>

    <!-- Scroll indicator -->
    <div
      id="scroll-indicator"
      class="absolute top-0 left-1/2 transform -translate-x-1/2 flex flex-col items-center mt-8"
    >
      <div
        class="w-8 h-12 border-2 border-terracotta rounded-full flex justify-center"
      >
        <div class="w-1 h-3 bg-terracotta rounded-full mt-2 animate-bounce">
        </div>
      </div>
    </div>
  </div>
</div>
